---
import Layout from '../../layouts/Layout.astro';
import { getServiceById, services } from '../../data/services';
import { serviceSchema, breadcrumbSchema } from '../../data/schema';

const { id } = Astro.params;
const service = getServiceById(id || '');

if (!service) return Astro.redirect('/404');

const schema = [
  serviceSchema(service.name.de, service.price, service.description?.de),
  breadcrumbSchema([
    { name: 'Startseite', url: '/' },
    { name: 'Services', url: '/services' },
    { name: service.name.de, url: `/service/${service.id}` },
  ]),
];

const relatedServices = services
  .filter(s => s.category === service.category && s.id !== service.id)
  .slice(0, 3);
---

<Layout
  title={`${service.name.de} | ${service.price}€ | Barbier Berlin Kreuzberg`}
  description={service.description?.de || `${service.name.de} bei Barbier Berlin in Kreuzberg für ${service.price}€. Jetzt online buchen!`}
  schema={schema}
>
  <section class="pt-32 pb-8 bg-[#050506]">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="text-sm text-[#8A8F98] mb-8">
        <a href="/" class="hover:text-[#C8A55A] transition-colors">Startseite</a>
        <span class="mx-2">/</span>
        <a href="/services" class="hover:text-[#C8A55A] transition-colors">Services</a>
        <span class="mx-2">/</span>
        <span class="text-[#EDEDEF]">{service.name.de}</span>
      </nav>

      <!-- Service Header -->
      <div class="bg-white/[0.03] backdrop-blur-sm rounded-2xl p-8 border border-white/[0.06]">
        <div class="flex items-start justify-between gap-6">
          <div>
            <h1 class="text-3xl sm:text-4xl font-display font-bold text-[#EDEDEF]">{service.name.de}</h1>
            <p class="mt-2 text-[#8A8F98]">ca. {service.duration} Minuten</p>
          </div>
          <div class="text-4xl font-display font-bold text-[#C8A55A] whitespace-nowrap">{service.price}€</div>
        </div>

        {service.description?.de && (
          <p class="mt-6 text-[#8A8F98] leading-relaxed text-lg">{service.description.de}</p>
        )}

        <a
          href="/booking"
          class="mt-8 inline-flex items-center gap-2 bg-gradient-to-r from-[#C8A55A] to-[#B8953A] text-[#050506] font-semibold px-8 py-4 rounded-full hover:shadow-lg hover:shadow-[#C8A55A]/20 transition-all"
        >
          Jetzt buchen
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="py-16 bg-[#0a0a0c]">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-xl font-display font-bold text-[#EDEDEF] mb-6">Weitere Services</h2>
        <div class="grid gap-4">
          {relatedServices.map(s => (
            <a href={`/service/${s.id}`} class="group bg-white/[0.03] rounded-xl p-5 border border-white/[0.06] hover:border-[#C8A55A]/30 transition-all flex items-center justify-between">
              <div>
                <h3 class="text-[#EDEDEF] font-medium group-hover:text-[#C8A55A] transition-colors">{s.name.de}</h3>
                <p class="text-[#8A8F98] text-sm">ca. {s.duration} Min.</p>
              </div>
              <span class="text-xl font-display font-bold text-[#C8A55A]">{s.price}€</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
