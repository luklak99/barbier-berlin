---
import Layout from '../../layouts/Layout.astro';
import BookingFlow from '../../components/booking/BookingFlow';
---

<Layout title="Randevu Al – Barbier Berlin" description="Barbier Berlin'de online randevu alın." lang="tr">
  <section class="pt-32 pb-8 bg-surface-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold-400 font-medium text-sm uppercase tracking-widest">Online Rezervasyon</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-display font-bold text-[var(--text)]">Randevu Al</h1>
      <p class="mt-4 text-[var(--text-muted)]">Hizmetinizi, tercih ettiğiniz saati seçin ve saniyeler içinde rezervasyon yapın.</p>
    </div>
  </section>

  <section class="pb-16 bg-surface-950 min-h-[60vh]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <BookingFlow lang="tr" client:load />
    </div>
  </section>
</Layout>
