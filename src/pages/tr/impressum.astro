---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Künye – Barbier Berlin" lang="tr">
  <section class="pt-32 pb-16 bg-surface-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-display font-bold text-[var(--text)] mb-8">Künye</h1>
      <div class="prose prose-invert prose-sm max-w-none space-y-6 text-[var(--text-subtle)]">
        <div>
          <h2 class="text-[var(--text)] text-xl font-semibold mb-2">§ 5 TMG uyarınca bilgiler</h2>
          <p>
            Barbier Berlin<br />
            Markgrafenstraße 88<br />
            10969 Berlin
          </p>
        </div>

        <div>
          <h2 class="text-[var(--text)] text-xl font-semibold mb-2">İletişim</h2>
          <p>
            Telefon: 030 259 265 00<br />
            E-Posta: info@barbier.berlin
          </p>
        </div>

        <div>
          <h2 class="text-[var(--text)] text-xl font-semibold mb-2">§ 55 Abs. 2 RStV uyarınca içerikten sorumlu kişi</h2>
          <p>
            Mohammed<br />
            Markgrafenstraße 88<br />
            10969 Berlin
          </p>
        </div>

        <div>
          <h2 class="text-[var(--text)] text-xl font-semibold mb-2">Uyuşmazlık Çözümü</h2>
          <p>
            Avrupa Komisyonu, çevrimiçi uyuşmazlık çözümü (ODR) için bir platform sunmaktadır:
            <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer" class="text-gold-400 hover:text-gold-300">
              https://ec.europa.eu/consumers/odr/
            </a>
          </p>
          <p>
            Bir tüketici tahkim kurulu önünde uyuşmazlık çözüm prosedürlerine katılmaya
            istekli değiliz ve yükümlü de değiliz.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
