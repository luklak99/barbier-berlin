---
import Layout from '../../../layouts/Layout.astro';
import { getServiceById, services } from '../../../data/services';
import { serviceSchema, breadcrumbSchema } from '../../../data/schema';

const lang = 'tr' as const;

const { id } = Astro.params;
const service = getServiceById(id || '');

if (!service) return Astro.redirect('/404');

const name = service.name[lang];
const description = service.description?.[lang] || service.description?.de;

const schema = [
  serviceSchema(name, service.price, description),
  breadcrumbSchema([
    { name: 'Ana Sayfa', url: '/tr/' },
    { name: 'Hizmetler', url: '/tr/services' },
    { name: name, url: `/tr/service/${service.id}` },
  ]),
];

const relatedServices = services
  .filter(s => s.category === service.category && s.id !== service.id)
  .slice(0, 3);
---

<Layout
  title={`${name} | ${service.price}€ | Barbier Berlin Kreuzberg`}
  description={description || `${name} - Barbier Berlin Kreuzberg, ${service.price}€. Hemen rezervasyon yapın!`}
  schema={schema}
  lang={lang}
>
  <section class="pt-32 pb-8 bg-[var(--bg)]">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="text-sm text-[var(--text-muted)] mb-8">
        <a href="/tr/" class="hover:text-[#C8A55A] transition-colors">Ana Sayfa</a>
        <span class="mx-2">/</span>
        <a href="/tr/services" class="hover:text-[#C8A55A] transition-colors">Hizmetler</a>
        <span class="mx-2">/</span>
        <span class="text-[var(--text)]">{name}</span>
      </nav>

      <!-- Service Header -->
      <div class="bg-[var(--glass)] backdrop-blur-sm rounded-2xl p-8 border border-[var(--border)]">
        <div class="flex items-start justify-between gap-6">
          <div>
            <h1 class="text-3xl sm:text-4xl font-display font-bold text-[var(--text)]">{name}</h1>
            <p class="mt-2 text-[var(--text-muted)]">yaklaşık {service.duration} dk.</p>
          </div>
          <div class="text-4xl font-display font-bold text-[#C8A55A] whitespace-nowrap">{service.price}€</div>
        </div>

        {description && (
          <p class="mt-6 text-[var(--text-muted)] leading-relaxed text-lg">{description}</p>
        )}

        <a
          href="/tr/booking"
          class="mt-8 inline-flex items-center gap-2 bg-gradient-to-r from-[#C8A55A] to-[#B8953A] text-[#050506] font-semibold px-8 py-4 rounded-full hover:shadow-lg hover:shadow-[#C8A55A]/20 transition-all"
        >
          Şimdi Rezervasyon
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServices.length > 0 && (
    <section class="py-16 bg-[var(--bg-elevated)]">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-xl font-display font-bold text-[var(--text)] mb-6">Diğer Hizmetler</h2>
        <div class="grid gap-4">
          {relatedServices.map(s => (
            <a href={`/tr/service/${s.id}`} class="group bg-[var(--glass)] rounded-xl p-5 border border-[var(--border)] hover:border-[#C8A55A]/30 transition-all flex items-center justify-between">
              <div>
                <h3 class="text-[var(--text)] font-medium group-hover:text-[#C8A55A] transition-colors">{s.name[lang]}</h3>
                <p class="text-[var(--text-muted)] text-sm">yaklaşık {s.duration} dk.</p>
              </div>
              <span class="text-xl font-display font-bold text-[#C8A55A]">{s.price}€</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
