---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/gallery/GalleryGrid';
import { webPageSchema, breadcrumbSchema } from '../data/schema';

const gallerySchema = [
  webPageSchema('Galerie – Barbier Berlin', 'Einblicke in Barbier Berlin: Haarschnitte, Bartpflege, Styling. Kreuzberg.', '/gallery'),
  breadcrumbSchema([{ name: 'Startseite', url: '/' }, { name: 'Galerie', url: '/gallery' }]),
];

const images = [
  { src: 'https://images.unsplash.com/photo-1585747860019-8e79ff236798?w=600&h=600&fit=crop', alt: 'Haarschnitt' },
  { src: 'https://images.unsplash.com/photo-1503951914875-452162b0f3f1?w=600&h=800&fit=crop', alt: 'Klassische Rasur' },
  { src: 'https://images.unsplash.com/photo-1621605815971-fbc98d665033?w=600&h=600&fit=crop', alt: 'Bartpflege' },
  { src: 'https://images.unsplash.com/photo-1599351431202-1e0f0137899a?w=600&h=800&fit=crop', alt: 'Styling' },
  { src: 'https://images.unsplash.com/photo-1622286342621-4bd786c2447c?w=600&h=600&fit=crop', alt: 'Barbershop Interior' },
  { src: 'https://images.unsplash.com/photo-1596728325488-58c87691e9af?w=600&h=600&fit=crop', alt: 'Detail Arbeit' },
  { src: 'https://images.unsplash.com/photo-1605497788044-5a32c7078486?w=600&h=800&fit=crop', alt: 'Fade Cut' },
  { src: 'https://images.unsplash.com/photo-1567894340315-735d7c361db0?w=600&h=600&fit=crop', alt: 'Barber Tools' },
  { src: 'https://images.unsplash.com/photo-1493256338651-d82f7acb2b38?w=600&h=600&fit=crop', alt: 'Barber Chair' },
];
---

<Layout title="Galerie | Barbier Berlin Kreuzberg | Unsere Arbeit" description="Galerie von Barbier Berlin — Haarschnitte, Bartpflege und Styling in Kreuzberg. Einblicke in unseren Salon und unsere Arbeit." schema={gallerySchema}>
  <section class="pt-32 pb-16 bg-[#050506]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">Unsere Arbeit</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-[#EDEDEF]">Galerie</h1>
      <p class="mt-4 text-[#8A8F98] max-w-2xl mx-auto text-lg">
        Einblicke in unseren Salon und unsere Arbeit.
      </p>
    </div>
  </section>

  <section class="py-16 bg-[#0a0a0c]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <GalleryGrid images={images} client:visible />
    </div>
  </section>
</Layout>
