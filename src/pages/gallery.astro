---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/gallery/GalleryGrid';
import { webPageSchema, breadcrumbSchema } from '../data/schema';

const gallerySchema = [
  webPageSchema('Galerie – Barbier Berlin', 'Einblicke in Barbier Berlin: Haarschnitte, Bartpflege, Styling. Kreuzberg.', '/gallery'),
  breadcrumbSchema([{ name: 'Startseite', url: '/' }, { name: 'Galerie', url: '/gallery' }]),
];

const images = [
  { src: '/images/gallery/v2.i1470510.w1280.h800.x433899B3.webp', alt: 'Barbier Berlin – Außenansicht Markgrafenstraße Kreuzberg' },
  { src: '/images/gallery/v2.i1470502.w1280.h800.xF3148E0E.webp', alt: 'Unser Salon – Klassische Barber-Stühle und Premium-Ausstattung' },
  { src: '/images/gallery/v2.i1470504.w1280.h800.x49C07302.webp', alt: 'Arbeitsplätze mit Blick auf die Markgrafenstraße' },
  { src: '/images/gallery/v2.i1470505.w1280.h800.xBFE612BC.webp', alt: 'Waschplatz und Barbier-Stühle' },
  { src: '/images/gallery/v2.i1470509.w1280.h800.xD6594E03.webp', alt: 'H.ZONE Essential Beard Oil – Premium Bartpflege-Produkte' },
  { src: '/images/gallery/v2.i1470506.w1280.h800.x36F238B7.webp', alt: 'Professionelles Barber-Zubehör – Sprühflaschen und Rasierpinsel' },
];
---

<Layout title="Galerie | Barbier Berlin Kreuzberg | Unsere Arbeit" description="Galerie von Barbier Berlin — Haarschnitte, Bartpflege und Styling in Kreuzberg. Einblicke in unseren Salon und unsere Arbeit." schema={gallerySchema}>
  <section class="pt-32 pb-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">Unsere Arbeit</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-[var(--text)]">Galerie</h1>
      <p class="mt-4 text-[var(--text-muted)] max-w-2xl mx-auto text-lg">
        Einblicke in unseren Salon und unsere Arbeit.
      </p>
    </div>
  </section>

  <section class="py-16 bg-[var(--bg-elevated)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <GalleryGrid images={images} client:visible />
    </div>
  </section>
</Layout>
