---
import Layout from '../layouts/Layout.astro';
import BookingFlow from '../components/booking/BookingFlow';
---

<Layout title="Termin buchen – Barbier Berlin" description="Buchen Sie Ihren Wunschtermin online bei Barbier Berlin.">
  <section class="pt-32 pb-8 bg-surface-950">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold-400 font-medium text-sm uppercase tracking-widest">Online-Buchung</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-display font-bold text-white">Termin buchen</h1>
      <p class="mt-4 text-white/50">Wählen Sie Ihren Service, Wunschtermin und buchen Sie in Sekunden.</p>
    </div>
  </section>

  <section class="pb-16 bg-surface-950 min-h-[60vh]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <BookingFlow lang="de" client:load />
    </div>
  </section>
</Layout>
