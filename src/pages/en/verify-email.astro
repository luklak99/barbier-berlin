---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Verify Email – Barbier Berlin" lang="en" noindex={true}>
  <section class="pt-32 pb-16 min-h-screen bg-[#050506] flex flex-col items-center justify-center">
    <div class="max-w-md w-full mx-auto px-4 text-center">
      <div id="verify-loading">
        <div class="w-12 h-12 border-2 border-[#C8A55A] border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-[#8A8F98]">Verifying email...</p>
      </div>
      <div id="verify-success" class="hidden">
        <div class="w-16 h-16 rounded-full bg-green-500/20 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <h1 class="text-2xl font-display font-bold text-[#EDEDEF]">Email Verified!</h1>
        <p class="mt-2 text-[#8A8F98]">Your account is now fully activated.</p>
        <a href="/en/dashboard" class="mt-6 inline-block px-6 py-3 rounded-full bg-[#C8A55A] text-[#050506] font-semibold">Go to Dashboard</a>
      </div>
      <div id="verify-error" class="hidden">
        <h1 class="text-2xl font-display font-bold text-[#EDEDEF]">Verification Failed</h1>
        <p id="verify-error-msg" class="mt-2 text-red-400"></p>
        <a href="/en/login" class="mt-6 inline-block px-6 py-3 rounded-full border border-white/[0.1] text-[#EDEDEF] font-medium">Go to Login</a>
      </div>
    </div>
  </section>
  <script>
    (async () => {
      const token = new URLSearchParams(window.location.search).get('token');
      const loading = document.getElementById('verify-loading')!;
      const success = document.getElementById('verify-success')!;
      const error = document.getElementById('verify-error')!;
      const errorMsg = document.getElementById('verify-error-msg')!;
      if (!token) { loading.classList.add('hidden'); error.classList.remove('hidden'); errorMsg.textContent = 'No token provided.'; return; }
      try {
        const res = await fetch('/api/auth/verify-email', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ token }),
        });
        loading.classList.add('hidden');
        if (res.ok) { success.classList.remove('hidden'); }
        else { const d = await res.json(); error.classList.remove('hidden'); errorMsg.textContent = d.error || 'Error.'; }
      } catch { loading.classList.add('hidden'); error.classList.remove('hidden'); errorMsg.textContent = 'Connection error.'; }
    })();
  </script>
</Layout>
