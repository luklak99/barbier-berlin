---
import Layout from '../../layouts/Layout.astro';
import GalleryGrid from '../../components/gallery/GalleryGrid';
import { webPageSchema, breadcrumbSchema } from '../../data/schema';

const gallerySchema = [
  webPageSchema('Gallery – Barbier Berlin', 'Insights into Barbier Berlin: haircuts, beard care, styling. Kreuzberg.', '/en/gallery'),
  breadcrumbSchema([{ name: 'Home', url: '/en' }, { name: 'Gallery', url: '/en/gallery' }]),
];

const images = [
  { src: '/images/gallery/v2.i1470510.w1280.h800.x433899B3.webp', alt: 'Barbier Berlin – Exterior view Markgrafenstraße Kreuzberg' },
  { src: '/images/gallery/v2.i1470502.w1280.h800.xF3148E0E.webp', alt: 'Our salon – Classic barber chairs and premium equipment' },
  { src: '/images/gallery/v2.i1470504.w1280.h800.x49C07302.webp', alt: 'Workstations with a view of Markgrafenstraße' },
  { src: '/images/gallery/v2.i1470505.w1280.h800.xBFE612BC.webp', alt: 'Wash station and barber chairs' },
  { src: '/images/gallery/v2.i1470509.w1280.h800.xD6594E03.webp', alt: 'H.ZONE Essential Beard Oil – Premium beard care products' },
  { src: '/images/gallery/v2.i1470506.w1280.h800.x36F238B7.webp', alt: 'Professional barber accessories – Spray bottles and shaving brushes' },
];
---

<Layout title="Gallery | Barbier Berlin Kreuzberg | Our Work" description="Gallery of Barbier Berlin — Haircuts, beard care and styling in Kreuzberg. Insights into our salon and our work." lang="en" schema={gallerySchema}>
  <section class="pt-32 pb-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">Our Work</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-[var(--text)]">Gallery</h1>
      <p class="mt-4 text-[var(--text-muted)] max-w-2xl mx-auto text-lg">
        Insights into our salon and our work.
      </p>
    </div>
  </section>

  <section class="py-16 bg-[var(--bg-elevated)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <GalleryGrid images={images} client:visible />
    </div>
  </section>
</Layout>
