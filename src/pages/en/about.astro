---
import Layout from '../../layouts/Layout.astro';
import { webPageSchema, breadcrumbSchema } from '../../data/schema';

const schema = [
  webPageSchema('About Us – Barbier Berlin', 'Barbier Berlin: Owner Mohammed, master barber since 2020 in Kreuzberg. 4.8★, 1,400+ reviews.', '/en/about'),
  breadcrumbSchema([{ name: 'Home', url: '/en' }, { name: 'About Us', url: '/en/about' }]),
];
---

<Layout title="About Us | Barbier Berlin Kreuzberg | Master Barber Mohammed" description="Get to know Barbier Berlin — founded in 2020 by master barber Mohammed in Kreuzberg. 4.8★ from 1,400+ reviews. Precision, hospitality & premium quality." lang="en" schema={schema}>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">Our Story</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-[var(--text)]">About Us</h1>
      <p class="mt-4 text-[var(--text-muted)] max-w-2xl mx-auto text-lg">
        Tradition meets modernity — in the heart of Kreuzberg.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 bg-[var(--bg-elevated)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">Since 2020</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold text-[var(--text)]">Our Story</h2>
          <div class="mt-2 h-0.5 w-16 bg-gradient-to-r from-[#C8A55A] to-transparent rounded-full"></div>
          <div class="mt-6 space-y-4 text-[var(--text-muted)] leading-relaxed">
            <p>
              Barbier Berlin was founded in 2020 by Mohammed on Markgrafenstraße in Berlin-Kreuzberg —
              with a clear vision: to bring first-class barbershop culture to Berlin.
            </p>
            <p>
              What started as a small shop has grown into one of Berlin's most popular barbershops,
              thanks to passion, precision, and honest craftsmanship.
              With over 1,400 positive reviews and a rating of 4.8 stars, the results speak for themselves.
            </p>
            <p>
              For us, it's not just about the haircut — it's about the experience.
              Every customer is greeted with a glass of tea or coffee while we take the time
              for personal consultation and precise work.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-[var(--glass)] border border-[var(--border)]">
            <img
              src="https://images.unsplash.com/photo-1621605815971-fbc98d665033?w=600&h=750&fit=crop"
              alt="Barbier Berlin Salon"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
          <!-- Glassmorphism stats badge -->
          <div class="absolute -bottom-6 -left-6 bg-[var(--glass-strong)] backdrop-blur-xl border border-[var(--border-strong)] rounded-2xl p-6 shadow-2xl">
            <div class="text-3xl font-display font-bold bg-gradient-to-r from-[#C8A55A] to-[#E8D48B] bg-clip-text text-transparent">5+</div>
            <div class="text-sm font-medium text-[var(--text-muted)]">Years of Experience</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Owner -->
  <section class="py-20 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="aspect-square rounded-2xl overflow-hidden bg-[var(--glass)] border border-[var(--border)] max-w-md mx-auto">
            <img
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&h=500&fit=crop&crop=face"
              alt="Mohammed — Owner & Master Barber"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">Owner & Master Barber</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold text-[var(--text)]">Mohammed</h2>
          <div class="mt-2 h-0.5 w-16 bg-gradient-to-r from-[#C8A55A] to-transparent rounded-full"></div>
          <div class="mt-6 space-y-4 text-[var(--text-muted)] leading-relaxed">
            <p>
              With years of experience and a passion for precise craftsmanship, Mohammed has made
              Barbier Berlin what it is today.
            </p>
            <p>
              His standard: Every customer leaves the salon with a smile.
              Whether classic cuts, modern styles, or the traditional wet shave —
              Mohammed masters his craft with attention to detail.
            </p>
            <p class="italic text-[color-mix(in_oklab,var(--text)_80%,transparent)] border-l-2 border-[#C8A55A]/40 pl-4">
              "For me, every haircut is a work of art. I take the time
              to find the perfect look for every customer."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 bg-[var(--bg-elevated)] border-y border-[var(--border)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { value: '5+', label: 'Years of Experience' },
          { value: '1,400+', label: 'Reviews' },
          { value: '4.8', label: 'Stars' },
          { value: '20+', label: 'Services' },
        ].map((stat) => (
          <div class="text-center">
            <div class="text-4xl sm:text-5xl font-display font-bold bg-gradient-to-r from-[#C8A55A] to-[#E8D48B] bg-clip-text text-transparent">{stat.value}</div>
            <div class="mt-2 text-sm text-[var(--text-muted)]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">What Sets Us Apart</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold text-[var(--text)]">Our Values</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Precision -->
        <div class="group bg-[var(--glass)] backdrop-blur-sm rounded-2xl p-8 border border-[var(--border)] hover:border-[#C8A55A]/20 transition-all duration-300 hover:shadow-lg hover:shadow-[#C8A55A]/5">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--text)]">Precision</h3>
          <p class="mt-2 text-[var(--text-muted)] leading-relaxed">Every cut is perfect. We work with the utmost care and the latest techniques.</p>
        </div>

        <!-- Hospitality -->
        <div class="group bg-[var(--glass)] backdrop-blur-sm rounded-2xl p-8 border border-[var(--border)] hover:border-[#C8A55A]/20 transition-all duration-300 hover:shadow-lg hover:shadow-[#C8A55A]/5">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.047 8.287 8.287 0 009 9.601a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.468 5.99 5.99 0 00-1.925 3.547 5.975 5.975 0 01-2.133-1.001A3.75 3.75 0 0012 18z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--text)]">Hospitality</h3>
          <p class="mt-2 text-[var(--text-muted)] leading-relaxed">Feel welcome with us. Tea, coffee, and good conversations included.</p>
        </div>

        <!-- Quality -->
        <div class="group bg-[var(--glass)] backdrop-blur-sm rounded-2xl p-8 border border-[var(--border)] hover:border-[#C8A55A]/20 transition-all duration-300 hover:shadow-lg hover:shadow-[#C8A55A]/5">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--text)]">Quality</h3>
          <p class="mt-2 text-[var(--text-muted)] leading-relaxed">Only the best products and tools. No compromises on quality.</p>
        </div>

        <!-- Personality -->
        <div class="group bg-[var(--glass)] backdrop-blur-sm rounded-2xl p-8 border border-[var(--border)] hover:border-[#C8A55A]/20 transition-all duration-300 hover:shadow-lg hover:shadow-[#C8A55A]/5">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--text)]">Personality</h3>
          <p class="mt-2 text-[var(--text-muted)] leading-relaxed">Every customer is unique. We provide individual consultation for the perfect look.</p>
        </div>

        <!-- Tradition -->
        <div class="group bg-[var(--glass)] backdrop-blur-sm rounded-2xl p-8 border border-[var(--border)] hover:border-[#C8A55A]/20 transition-all duration-300 hover:shadow-lg hover:shadow-[#C8A55A]/5">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--text)]">Tradition</h3>
          <p class="mt-2 text-[var(--text-muted)] leading-relaxed">Classic barbershop culture with a modern twist. The best of both worlds.</p>
        </div>

        <!-- Trust -->
        <div class="group bg-[var(--glass)] backdrop-blur-sm rounded-2xl p-8 border border-[var(--border)] hover:border-[#C8A55A]/20 transition-all duration-300 hover:shadow-lg hover:shadow-[#C8A55A]/5">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[var(--text)]">Trust</h3>
          <p class="mt-2 text-[var(--text-muted)] leading-relaxed">Over 1,400 satisfied customers. Our reputation speaks for itself.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
