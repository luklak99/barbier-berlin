---
import Layout from '../../layouts/Layout.astro';
import BookingFlow from '../../components/booking/BookingFlow';
---

<Layout title="Book Appointment – Barbier Berlin" description="Book your preferred appointment online at Barbier Berlin." lang="en">
  <section class="pt-32 pb-8 bg-[var(--bg)]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold-400 font-medium text-sm uppercase tracking-widest">Online Booking</span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-display font-bold text-[var(--text)]">Book Appointment</h1>
      <p class="mt-4 text-[var(--text-muted)]">Choose your service, preferred time, and book in seconds.</p>
    </div>
  </section>

  <section class="pb-16 bg-[var(--bg)] min-h-[60vh]">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <BookingFlow lang="en" client:load />
    </div>
  </section>
</Layout>
