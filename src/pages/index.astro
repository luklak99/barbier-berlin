---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import Marquee from '../components/home/Marquee.astro';
import GoldDivider from '../components/home/GoldDivider.astro';
import ServicesPreview from '../components/home/ServicesPreview.astro';
import Features from '../components/home/Features.astro';
import LiveReviews from '../components/home/LiveReviews.astro';
import CTASection from '../components/home/CTASection.astro';
import { barberShopSchema, websiteSchema, webPageSchema, breadcrumbSchema } from '../data/schema';

const schema = [
  barberShopSchema,
  websiteSchema,
  webPageSchema(
    'Barbier Berlin – Premium Barbershop in Kreuzberg',
    'Ihr Barbershop in Berlin-Kreuzberg. Haarschnitte ab 20€, Bartpflege, Nassrasur. 4.8★ aus 1.400+ Bewertungen. Online buchen!',
    '/',
  ),
  breadcrumbSchema([{ name: 'Startseite', url: '/' }]),
];
---

<Layout
  title="Barbier Berlin | Barbershop Berlin-Kreuzberg | Markgrafenstraße 88"
  description="Barbier Berlin – Ihr Premium-Barbershop in Kreuzberg. Haarschnitte ab 20€, Bartpflege, Nassrasur & Styling. 4.8★ aus 1.400+ Bewertungen. Jetzt online Termin buchen!"
  schema={schema}
>
  <Hero lang="de" />
  <Marquee lang="de" />
  <Features lang="de" />
  <GoldDivider />
  <ServicesPreview lang="de" />
  <GoldDivider />
  <LiveReviews lang="de" />
  <GoldDivider />
  <CTASection lang="de" />
</Layout>

<script>
  // Global IntersectionObserver for scroll-triggered animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
</script>
