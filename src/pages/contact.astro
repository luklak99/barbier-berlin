---
import Layout from '../layouts/Layout.astro';
import { webPageSchema, breadcrumbSchema } from '../data/schema';

const schema = [
  webPageSchema('Kontakt – Barbier Berlin', 'Barbier Berlin Kontakt: Markgrafenstraße 88, 10969 Berlin. Mo-Fr 10-18, Sa 10-17. Tel: 030 259 265 00.', '/contact'),
  breadcrumbSchema([{ name: 'Startseite', url: '/' }, { name: 'Kontakt', url: '/contact' }]),
];
---

<Layout title="Kontakt & Anfahrt | Barbier Berlin | Markgrafenstraße 88 Kreuzberg" description="Barbier Berlin besuchen: Markgrafenstraße 88, 10969 Berlin-Kreuzberg. Mo-Fr 10:00-18:00, Sa 10:00-17:00. Tel: 030 259 265 00. Karte & Anfahrt." schema={schema}>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">Besuchen Sie uns</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-[var(--text)]">Kontakt</h1>
      <p class="mt-4 text-[var(--text-muted)] max-w-2xl mx-auto text-lg">
        Im Herzen von Kreuzberg — perfekt erreichbar.
      </p>
    </div>
  </section>

  <section class="py-16 bg-[var(--bg-elevated)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Info -->
        <div class="space-y-6">
          <!-- Address -->
          <div class="group flex gap-4 bg-[var(--glass)] backdrop-blur-sm rounded-xl p-5 border border-[var(--border)] hover:border-[#C8A55A]/20 hover:shadow-lg hover:shadow-[#C8A55A]/5 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[var(--text)] text-lg">Adresse</h3>
              <p class="mt-1 text-[var(--text-muted)]">Markgrafenstraße 88</p>
              <p class="text-[var(--text-muted)]">10969 Berlin (Kreuzberg)</p>
              <a
                href="https://maps.app.goo.gl/Ed2sUihwZV5pMmHb6"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-flex items-center gap-1 text-[#C8A55A] text-sm font-medium hover:text-[#E8D48B] transition-colors duration-300"
              >
                Route planen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="group flex gap-4 bg-[var(--glass)] backdrop-blur-sm rounded-xl p-5 border border-[var(--border)] hover:border-[#C8A55A]/20 hover:shadow-lg hover:shadow-[#C8A55A]/5 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[var(--text)] text-lg">Telefon</h3>
              <a href="tel:+493025926500" class="mt-1 text-[var(--text-muted)] hover:text-[#C8A55A] transition-colors duration-300 text-lg">
                030 259 265 00
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="group flex gap-4 bg-[var(--glass)] backdrop-blur-sm rounded-xl p-5 border border-[var(--border)] hover:border-[#C8A55A]/20 hover:shadow-lg hover:shadow-[#C8A55A]/5 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[var(--text)] text-lg">E-Mail</h3>
              <a href="mailto:info@barbier.berlin" class="mt-1 text-[var(--text-muted)] hover:text-[#C8A55A] transition-colors duration-300">
                info@barbier.berlin
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="group flex gap-4 bg-[var(--glass)] backdrop-blur-sm rounded-xl p-5 border border-[var(--border)] hover:border-[#C8A55A]/20 hover:shadow-lg hover:shadow-[#C8A55A]/5 transition-all duration-300">
            <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="font-semibold text-[var(--text)] text-lg">Öffnungszeiten</h3>
              <div class="mt-2 space-y-2">
                <div class="flex justify-between gap-8 text-[var(--text-muted)]">
                  <span>Montag – Freitag</span>
                  <span class="font-medium text-[var(--text)]">10:00 – 18:00</span>
                </div>
                <div class="flex justify-between gap-8 text-[var(--text-muted)]">
                  <span>Samstag</span>
                  <span class="font-medium text-[var(--text)]">10:00 – 17:00</span>
                </div>
                <div class="flex justify-between gap-8 text-[var(--text-muted)]">
                  <span>Sonntag</span>
                  <span class="font-medium text-[#C8A55A]">Geschlossen</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Amenities -->
          <div class="bg-[var(--glass)] backdrop-blur-sm rounded-xl p-5 border border-[var(--border)]">
            <h3 class="font-semibold text-[var(--text)] mb-3">Bei uns erwartet Sie</h3>
            <div class="flex flex-wrap gap-3">
              <!-- Kaffee & Tee -->
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--glass)] border border-[var(--border)] text-sm text-[var(--text)] hover:border-[#C8A55A]/20 transition-all duration-300">
                <svg class="w-4 h-4 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.047 8.287 8.287 0 009 9.601a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.468 5.99 5.99 0 00-1.925 3.547 5.975 5.975 0 01-2.133-1.001A3.75 3.75 0 0012 18z" /></svg>
                Kaffee & Tee
              </span>
              <!-- Wasser -->
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--glass)] border border-[var(--border)] text-sm text-[var(--text)] hover:border-[#C8A55A]/20 transition-all duration-300">
                <svg class="w-4 h-4 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a8 8 0 008-8c0-3.5-2.5-6.5-5-9.5L12 0l-3 3.5C6.5 6.5 4 9.5 4 13a8 8 0 008 8z" /></svg>
                Wasser
              </span>
              <!-- WLAN -->
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--glass)] border border-[var(--border)] text-sm text-[var(--text)] hover:border-[#C8A55A]/20 transition-all duration-300">
                <svg class="w-4 h-4 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" /></svg>
                Kostenloses WLAN
              </span>
              <!-- Musik -->
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--glass)] border border-[var(--border)] text-sm text-[var(--text)] hover:border-[#C8A55A]/20 transition-all duration-300">
                <svg class="w-4 h-4 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z" /></svg>
                Entspannte Musik
              </span>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="relative">
          <div class="sticky top-24 rounded-2xl overflow-hidden border-2 border-[#C8A55A]/20 shadow-lg shadow-[#C8A55A]/5">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2429.5!2d13.3923!3d52.5033!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47a8515dcac450fd%3A0x24baaa37ffa5161b!2sBarbier.Berlin!5e0!3m2!1sde!2sde!4v1700000000000"
              width="100%"
              height="500"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Barbier Berlin auf Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
