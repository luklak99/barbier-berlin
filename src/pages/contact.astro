---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt – Barbier Berlin" description="Besuchen Sie uns in Berlin-Kreuzberg. Adresse, Öffnungszeiten und Anfahrt.">
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-surface-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-gold-400 font-medium text-sm uppercase tracking-widest">Besuchen Sie uns</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-white">Kontakt</h1>
      <p class="mt-4 text-white/50 max-w-2xl mx-auto text-lg">
        Im Herzen von Kreuzberg — perfekt erreichbar.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Info -->
        <div class="space-y-10">
          <!-- Address -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-surface-900 text-lg">Adresse</h3>
              <p class="mt-1 text-surface-200">Markgrafenstraße 88</p>
              <p class="text-surface-200">10969 Berlin (Kreuzberg)</p>
              <a
                href="https://maps.app.goo.gl/Ed2sUihwZV5pMmHb6"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-2 inline-flex items-center gap-1 text-gold-600 text-sm font-medium hover:text-gold-700 transition-colors"
              >
                Route planen
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-surface-900 text-lg">Telefon</h3>
              <a href="tel:+493025926500" class="mt-1 text-surface-200 hover:text-gold-600 transition-colors text-lg">
                030 259 265 00
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-surface-900 text-lg">E-Mail</h3>
              <a href="mailto:info@barbier.berlin" class="mt-1 text-surface-200 hover:text-gold-600 transition-colors">
                info@barbier.berlin
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="flex gap-4">
            <div class="w-12 h-12 rounded-xl bg-gold-500/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-surface-900 text-lg">Öffnungszeiten</h3>
              <div class="mt-2 space-y-2">
                <div class="flex justify-between gap-8 text-surface-200">
                  <span>Montag – Freitag</span>
                  <span class="font-medium text-surface-900">10:00 – 18:00</span>
                </div>
                <div class="flex justify-between gap-8 text-surface-200">
                  <span>Samstag</span>
                  <span class="font-medium text-surface-900">10:00 – 17:00</span>
                </div>
                <div class="flex justify-between gap-8 text-surface-200">
                  <span>Sonntag</span>
                  <span class="font-medium text-gold-600">Geschlossen</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Amenities -->
          <div class="bg-surface-50 rounded-2xl p-6 border border-surface-100">
            <h3 class="font-semibold text-surface-900 mb-3">Bei uns erwartet Sie</h3>
            <div class="flex flex-wrap gap-3">
              {['☕ Kaffee & Tee', '💧 Wasser', '📶 Kostenloses WLAN', '🎵 Entspannte Musik'].map((item) => (
                <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-white text-sm text-surface-800 border border-surface-100">
                  {item}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="relative">
          <div class="sticky top-24 rounded-2xl overflow-hidden border border-surface-100 shadow-lg">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2429.5!2d13.3923!3d52.5033!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47a8515dcac450fd%3A0x24baaa37ffa5161b!2sBarbier.Berlin!5e0!3m2!1sde!2sde!4v1700000000000"
              width="100%"
              height="500"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Barbier Berlin auf Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
