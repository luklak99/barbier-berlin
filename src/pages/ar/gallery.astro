---
import Layout from '../../layouts/Layout.astro';
import GalleryGrid from '../../components/gallery/GalleryGrid';
import { webPageSchema, breadcrumbSchema } from '../../data/schema';

const gallerySchema = [
  webPageSchema('المعرض – باربير برلين', 'باربير برلين: قصات شعر، عناية باللحية، تصفيف. كرويتسبرغ.', '/ar/gallery'),
  breadcrumbSchema([{ name: 'الرئيسية', url: '/ar' }, { name: 'المعرض', url: '/ar/gallery' }]),
];

const images = [
  { src: '/images/gallery/v2.i1470510.w1280.h800.x433899B3.webp', alt: 'باربير برلين – الواجهة الخارجية في ماركغرافنشتراسه كرويتسبرغ' },
  { src: '/images/gallery/v2.i1470502.w1280.h800.xF3148E0E.webp', alt: 'صالوننا – كراسي الحلاقة الكلاسيكية والمعدات الفاخرة' },
  { src: '/images/gallery/v2.i1470504.w1280.h800.x49C07302.webp', alt: 'محطات العمل مع إطلالة على ماركغرافنشتراسه' },
  { src: '/images/gallery/v2.i1470505.w1280.h800.xBFE612BC.webp', alt: 'محطة الغسيل وكراسي الحلاقة' },
  { src: '/images/gallery/v2.i1470509.w1280.h800.xD6594E03.webp', alt: 'زيت لحية H.ZONE Essential – منتجات عناية باللحية الفاخرة' },
  { src: '/images/gallery/v2.i1470506.w1280.h800.x36F238B7.webp', alt: 'أدوات الحلاقة الاحترافية – زجاجات الرش وفرش الحلاقة' },
];
---

<Layout title="المعرض | باربير برلين كرويتسبرغ | أعمالنا" description="معرض باربير برلين — قصات الشعر والعناية باللحية والتصفيف في كرويتسبرغ. لقطات من صالوننا وأعمالنا." lang="ar" schema={gallerySchema}>
  <section class="pt-32 pb-16 bg-[var(--bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">أعمالنا</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-[var(--text)]">المعرض</h1>
      <p class="mt-4 text-[var(--text-muted)] max-w-2xl mx-auto text-lg">
        لمحات من صالوننا وأعمالنا.
      </p>
    </div>
  </section>

  <section class="py-16 bg-[var(--bg-elevated)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <GalleryGrid images={images} client:visible />
    </div>
  </section>
</Layout>
