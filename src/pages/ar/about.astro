---
import Layout from '../../layouts/Layout.astro';
import { webPageSchema, breadcrumbSchema } from '../../data/schema';

const schema = [
  webPageSchema('من نحن – باربير برلين', 'باربير برلين: المالك محمد، حلاق ماهر منذ 2020 في كرويتسبرغ. 4.8★، أكثر من 1,400 تقييم.', '/ar/about'),
  breadcrumbSchema([{ name: 'الرئيسية', url: '/ar' }, { name: 'من نحن', url: '/ar/about' }]),
];
---

<Layout title="من نحن | باربير برلين كرويتسبرغ | الحلاق الماهر محمد" description="تعرف على باربير برلين — تأسس عام 2020 من قبل الحلاق الماهر محمد في كرويتسبرغ. 4.8★ من أكثر من 1,400 تقييم. دقة وضيافة وجودة فائقة." lang="ar" schema={schema}>
  <!-- Hero -->
  <section class="pt-32 pb-16 bg-[#050506]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">قصتنا</span>
      <h1 class="mt-3 text-4xl sm:text-6xl font-display font-bold text-[#EDEDEF]">من نحن</h1>
      <p class="mt-4 text-[#8A8F98] max-w-2xl mx-auto text-lg">
        التراث يلتقي بالحداثة — في قلب كرويتسبرغ.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 bg-[#0a0a0c]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">منذ عام 2020</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold text-[#EDEDEF]">قصتنا</h2>
          <div class="mt-2 h-0.5 w-16 bg-gradient-to-r from-[#C8A55A] to-transparent rounded-full"></div>
          <div class="mt-6 space-y-4 text-[#8A8F98] leading-relaxed">
            <p>
              تأسس باربير برلين عام 2020 على يد محمد في ماركغرافنشتراسه ببرلين-كرويتسبرغ —
              برؤية واضحة: جلب ثقافة الحلاقة الراقية إلى برلين.
            </p>
            <p>
              ما بدأ كمحل صغير نما ليصبح أحد أكثر صالونات الحلاقة شعبية في برلين،
              بفضل الشغف والدقة والحرفية الصادقة.
              مع أكثر من 1,400 تقييم إيجابي وتقييم 4.8 نجوم، النتائج تتحدث عن نفسها.
            </p>
            <p>
              بالنسبة لنا، الأمر لا يتعلق فقط بقصة الشعر — بل بالتجربة.
              كل عميل يُستقبل بكوب من الشاي أو القهوة بينما نأخذ الوقت
              للاستشارة الشخصية والعمل الدقيق.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-white/[0.03] border border-white/[0.06]">
            <img
              src="https://images.unsplash.com/photo-1621605815971-fbc98d665033?w=600&h=750&fit=crop"
              alt="صالون باربير برلين"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-6 -left-6 bg-white/[0.05] backdrop-blur-xl border border-white/[0.1] rounded-2xl p-6 shadow-2xl">
            <div class="text-3xl font-display font-bold bg-gradient-to-r from-[#C8A55A] to-[#E8D48B] bg-clip-text text-transparent">5+</div>
            <div class="text-sm font-medium text-[#8A8F98]">سنوات خبرة</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Owner -->
  <section class="py-20 bg-[#050506]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="aspect-square rounded-2xl overflow-hidden bg-white/[0.03] border border-white/[0.06] max-w-md mx-auto">
            <img
              src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&h=500&fit=crop&crop=face"
              alt="محمد — المالك والحلاق الماهر"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">المالك والحلاق الماهر</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold text-[#EDEDEF]">محمد</h2>
          <div class="mt-2 h-0.5 w-16 bg-gradient-to-r from-[#C8A55A] to-transparent rounded-full"></div>
          <div class="mt-6 space-y-4 text-[#8A8F98] leading-relaxed">
            <p>
              بسنوات من الخبرة وشغف بالحرفية الدقيقة، جعل محمد
              باربير برلين ما هو عليه اليوم.
            </p>
            <p>
              معياره: كل عميل يغادر الصالون بابتسامة.
              سواء كانت قصات كلاسيكية أو أساليب حديثة أو الحلاقة التقليدية —
              يتقن محمد حرفته باهتمام بالتفاصيل.
            </p>
            <p class="italic text-[#EDEDEF]/80 border-r-2 border-[#C8A55A]/40 pr-4">
              "بالنسبة لي، كل قصة شعر هي عمل فني. أخذ الوقت
              للعثور على المظهر المثالي لكل عميل."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 bg-[#0a0a0c] border-y border-white/[0.06]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { value: '+5', label: 'سنوات خبرة' },
          { value: '+1,400', label: 'تقييمات' },
          { value: '4.8', label: 'نجوم' },
          { value: '+20', label: 'خدمات' },
        ].map((stat) => (
          <div class="text-center">
            <div class="text-4xl sm:text-5xl font-display font-bold bg-gradient-to-r from-[#C8A55A] to-[#E8D48B] bg-clip-text text-transparent">{stat.value}</div>
            <div class="mt-2 text-sm text-[#8A8F98]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-[#050506]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-[#C8A55A] font-medium text-sm uppercase tracking-widest">ما يميزنا</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold text-[#EDEDEF]">قيمنا</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="group bg-white/[0.03] backdrop-blur-sm rounded-2xl p-8 border border-white/[0.06] hover:border-[#C8A55A]/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h3 class="text-xl font-semibold text-[#EDEDEF]">الدقة</h3>
          <p class="mt-2 text-[#8A8F98] leading-relaxed">كل قصة مثالية. نعمل بأقصى قدر من العناية وأحدث التقنيات.</p>
        </div>

        <div class="group bg-white/[0.03] backdrop-blur-sm rounded-2xl p-8 border border-white/[0.06] hover:border-[#C8A55A]/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.047 8.287 8.287 0 009 9.601a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[#EDEDEF]">الضيافة</h3>
          <p class="mt-2 text-[#8A8F98] leading-relaxed">اشعر بالترحيب عندنا. الشاي والقهوة والمحادثات الجيدة مشمولة.</p>
        </div>

        <div class="group bg-white/[0.03] backdrop-blur-sm rounded-2xl p-8 border border-white/[0.06] hover:border-[#C8A55A]/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[#EDEDEF]">الجودة</h3>
          <p class="mt-2 text-[#8A8F98] leading-relaxed">أفضل المنتجات والأدوات فقط. لا تنازلات في الجودة.</p>
        </div>

        <div class="group bg-white/[0.03] backdrop-blur-sm rounded-2xl p-8 border border-white/[0.06] hover:border-[#C8A55A]/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[#EDEDEF]">الشخصية</h3>
          <p class="mt-2 text-[#8A8F98] leading-relaxed">كل عميل فريد. نقدم استشارة فردية للحصول على المظهر المثالي.</p>
        </div>

        <div class="group bg-white/[0.03] backdrop-blur-sm rounded-2xl p-8 border border-white/[0.06] hover:border-[#C8A55A]/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[#EDEDEF]">التراث</h3>
          <p class="mt-2 text-[#8A8F98] leading-relaxed">ثقافة الحلاقة الكلاسيكية بلمسة عصرية. أفضل ما في العالمين.</p>
        </div>

        <div class="group bg-white/[0.03] backdrop-blur-sm rounded-2xl p-8 border border-white/[0.06] hover:border-[#C8A55A]/20 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[#C8A55A]/10 border border-[#C8A55A]/20 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-[#C8A55A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
          </div>
          <h3 class="text-xl font-semibold text-[#EDEDEF]">الثقة</h3>
          <p class="mt-2 text-[#8A8F98] leading-relaxed">أكثر من 1,400 عميل راضٍ. سمعتنا تتحدث عن نفسها.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
