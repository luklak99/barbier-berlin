---
// CTA Section — Pure Astro, no React, no Framer Motion
import { t, type Language } from '../../i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = 'de' } = Astro.props;
const tr = t(lang);
const prefix = lang === 'de' ? '' : `/${lang}`;
---

<section
  class="relative py-24 overflow-hidden"
  style="background: linear-gradient(180deg, var(--bg-deep) 0%, var(--bg-elevated-2) 50%, var(--bg-deep) 100%);"
>
  <!-- Noise overlay -->
  <div
    class="absolute inset-0 opacity-[0.025] pointer-events-none"
    style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E&quot;); background-repeat: repeat; background-size: 128px 128px;"
  ></div>

  <!-- Ambient orbs -->
  <div
    class="absolute top-[20%] left-[30%] w-[400px] h-[400px] rounded-full pointer-events-none cta-orb-1"
    style="background: radial-gradient(circle, rgba(200,165,90,0.08) 0%, transparent 70%); filter: blur(100px);"
  ></div>
  <div
    class="absolute bottom-[10%] right-[20%] w-[300px] h-[300px] rounded-full pointer-events-none cta-orb-2"
    style="background: radial-gradient(circle, rgba(200,165,90,0.06) 0%, transparent 70%); filter: blur(80px);"
  ></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Glassmorphism container -->
    <div
      class="animate-on-scroll relative rounded-3xl px-8 py-16 sm:px-16 text-center overflow-hidden"
      style="background: var(--glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid var(--border); box-shadow: inset 0 1px 0 0 var(--glass-strong), 0 0 60px rgba(200,165,90,0.03);"
    >
      <!-- Shimmer effect - top edge -->
      <div
        class="absolute top-0 left-0 right-0 h-[1px]"
        style="background: linear-gradient(90deg, transparent 0%, rgba(200,165,90,0.3) 50%, transparent 100%);"
      ></div>

      <!-- Shimmer animation overlay -->
      <div
        class="absolute inset-0 pointer-events-none opacity-[0.03] cta-shimmer"
        style="background: linear-gradient(105deg, transparent 40%, rgba(200,165,90,0.8) 45%, rgba(200,165,90,0.8) 55%, transparent 60%); background-size: 200% 100%;"
      ></div>

      <h2 class="text-4xl sm:text-5xl font-display font-bold" style="color: var(--text);">
        {tr.home.ctaPre}<span
          class="inline"
          style="background: linear-gradient(135deg, #d4b86a 0%, #C8A55A 40%, #b8943e 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        > {tr.home.ctaHighlight}</span>?
      </h2>

      <p class="mt-4 text-lg" style="color: var(--text-muted);">
        {tr.home.ctaSubtitle}
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`${prefix}/booking`}
          class="relative inline-flex items-center gap-2 font-semibold px-8 py-4 rounded-full transition-all hover:scale-[1.02] active:scale-[0.97]"
          style="background: linear-gradient(135deg, #C8A55A 0%, #d4b86a 50%, #b8943e 100%); color: #050506; box-shadow: 0 0 30px rgba(200,165,90,0.15), 0 4px 20px rgba(200,165,90,0.2);"
        >
          {tr.home.ctaButton}
          <svg class={`w-5 h-5 ${lang === 'ar' ? 'rotate-180' : ''}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>

        <a
          href="tel:+493025926500"
          class="inline-flex items-center gap-2 font-medium transition-all px-6 py-4 rounded-full hover:scale-[1.02] active:scale-[0.97]"
          style="color: var(--text-subtle); border: 1px solid var(--border-strong); background: var(--glass);"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #C8A55A;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          030 259 265 00
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-orb-1 {
    animation: ctaOrb1Float 16s linear infinite;
  }
  .cta-orb-2 {
    animation: ctaOrb2Float 22s linear infinite;
  }
  .cta-shimmer {
    animation: shimmer-cta 6s ease-in-out infinite;
  }

  @keyframes ctaOrb1Float {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(60px, -40px); }
    66% { transform: translate(0px, 0px); }
  }
  @keyframes ctaOrb2Float {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(-40px, 30px); }
    66% { transform: translate(0px, 0px); }
  }
  @keyframes shimmer-cta {
    0%, 100% { background-position: 200% 0; }
    50% { background-position: -200% 0; }
  }
</style>
