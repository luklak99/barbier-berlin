---
import type { Language } from '../../i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = 'de' } = Astro.props;

const items: Record<Language, string[]> = {
  de: ['Haarschnitt', 'Bartpflege', 'Nassrasur', 'Styling', 'Premium', 'Kreuzberg', 'Seit 2020'],
  en: ['Haircut', 'Beard Care', 'Wet Shave', 'Styling', 'Premium', 'Kreuzberg', 'Since 2020'],
  tr: ['Saç Kesimi', 'Sakal Bakımı', 'Islak Tıraş', 'Styling', 'Premium', 'Kreuzberg', "2020'den Beri"],
  ar: ['قص الشعر', 'العناية باللحية', 'الحلاقة الرطبة', 'تصفيف', 'مميز', 'كرويتسبرغ', 'منذ 2020'],
};

const currentItems = items[lang];
---

<div class="relative py-6 overflow-hidden" style="background: color-mix(in oklab, var(--gold) 4%, transparent); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
  <div class={`marquee-track flex gap-8 whitespace-nowrap ${lang === 'ar' ? 'marquee-rtl' : ''}`} style="width: max-content;">
    {[...Array(3)].map(() => (
      <div class="flex items-center gap-8 text-sm font-display font-semibold uppercase tracking-[0.25em]" style="color: color-mix(in oklab, var(--gold) 60%, transparent);">
        {currentItems.map((item, i) => (
          <>
            <span>{item}</span>
            {i < currentItems.length - 1 && (
              <span style="color: color-mix(in oklab, var(--gold) 30%, transparent);">◆</span>
            )}
          </>
        ))}
        <span style="color: color-mix(in oklab, var(--gold) 30%, transparent);">◆</span>
      </div>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marqueeScroll 25s linear infinite;
  }
  .marquee-rtl {
    animation: marqueeScrollRtl 25s linear infinite;
  }
  @keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
  @keyframes marqueeScrollRtl {
    0% { transform: translateX(-33.333%); }
    100% { transform: translateX(0); }
  }
</style>
