---
import { t, languages, type Language } from '../../i18n/translations';
import MobileNav from './MobileNav';

interface Props {
  lang?: Language;
}

const { lang = 'de' } = Astro.props;
const tr = t(lang);

// Compute base path (without language prefix) for language switcher
const currentPath = Astro.url.pathname;
const basePath = currentPath.replace(/^\/(en|tr|ar)(\/|$)/, '/');
const basePage = basePath === '/' ? '' : basePath;
const prefix = lang === 'de' ? '' : `/${lang}`;
const homeHref = prefix || '/';

// Build href for switching to a target language while staying on the same page
function langUrl(code: string): string {
  const p = code === 'de' ? '' : `/${code}`;
  return `${p}${basePage}` || '/';
}
const langUrls = Object.fromEntries(Object.keys(languages).map(code => [code, langUrl(code)])) as Record<string, string>;
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-header">
  <div class="absolute inset-0 bg-[#050506]/80 backdrop-blur-2xl border-b border-white/[0.06]"></div>
  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 transition-all duration-500" id="header-inner">
      <!-- Logo -->
      <a href={homeHref} class="flex items-center gap-3 group">
        <img
          src="/images/logo.svg"
          alt="Barbier Berlin Logo"
          width="44"
          height="44"
          class="w-11 h-11 transition-transform duration-300 group-hover:scale-110"
        />
        <div class="hidden sm:block">
          <span class="text-[#EDEDEF] font-display text-xl font-semibold tracking-wide">Barbier</span>
          <span class="text-[#C8A55A] font-display text-xl font-light ml-1">Berlin</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        <a href={homeHref} class="nav-link">{tr.nav.home}</a>
        <a href={`${prefix}/services`} class="nav-link">{tr.nav.services}</a>
        <a href={`${prefix}/gallery`} class="nav-link">{tr.nav.gallery}</a>
        <a href={`${prefix}/about`} class="nav-link">{tr.nav.about}</a>
        <a href={`${prefix}/contact`} class="nav-link">{tr.nav.contact}</a>
      </div>

      <!-- Right Side -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Language Switcher -->
        <div class="relative group">
          <button class="flex items-center gap-1.5 text-[#8A8F98] hover:text-[#EDEDEF] text-sm px-2 py-1 transition-colors uppercase tracking-wider font-medium">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-width="1.5" d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            {lang}
          </button>
          <div class="absolute right-0 top-full mt-2 bg-[#0a0a0c]/95 backdrop-blur-xl border border-white/[0.08] rounded-xl py-1.5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-2xl shadow-black/40">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={langUrls[code]}
                class={`block px-5 py-2 text-sm whitespace-nowrap transition-colors ${
                  code === lang ? 'text-[#C8A55A]' : 'text-[#8A8F98] hover:text-[#EDEDEF] hover:bg-white/[0.04]'
                }`}
              >
                {name}
              </a>
            ))}
          </div>
        </div>

        <a href={`${prefix}/login`} class="text-[#8A8F98] hover:text-[#EDEDEF] text-sm transition-colors px-3 py-2">
          {tr.nav.login}
        </a>
        <a
          href={`${prefix}/booking`}
          class="bg-gradient-to-r from-[#C8A55A] to-[#B8953A] hover:from-[#D8B56A] hover:to-[#C8A55A] text-[#050506] font-semibold text-sm px-5 py-2.5 rounded-full transition-all duration-300 shadow-lg shadow-[#C8A55A]/20 hover:shadow-xl hover:shadow-[#C8A55A]/30 active:scale-95"
        >
          {tr.nav.booking}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <MobileNav lang={lang} prefix={prefix} langUrls={langUrls} client:load />
    </div>
  </nav>
</header>

<style>
  @reference "../../styles/global.css";
  .nav-link {
    @apply relative text-[#8A8F98] hover:text-[#EDEDEF] text-sm font-medium px-3 py-2 transition-colors duration-300;
  }
  .nav-link::after {
    content: '';
    @apply absolute bottom-0 left-3 right-3 h-[2px] bg-[#C8A55A] scale-x-0 origin-left transition-transform duration-300;
  }
  .nav-link:hover::after {
    @apply scale-x-100;
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const headerInner = document.getElementById('header-inner');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (header && headerInner) {
      if (scrollY > 50) {
        headerInner.style.height = '3.5rem';
        header.classList.add('header-scrolled');
      } else {
        headerInner.style.height = '';
        header.classList.remove('header-scrolled');
      }
    }
    lastScroll = scrollY;
  });
</script>
