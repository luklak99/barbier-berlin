---
import { t, languages, type Language } from '../../i18n/translations';
import MobileNav from './MobileNav';
import ThemeToggle from '../ui/ThemeToggle.astro';

interface Props {
  lang?: Language;
}

const { lang = 'de' } = Astro.props;
const tr = t(lang);

// Compute base path (without language prefix) for language switcher
const currentPath = Astro.url.pathname;
const basePath = currentPath.replace(/^\/(en|tr|ar)(\/|$)/, '/');
const basePage = basePath === '/' ? '' : basePath;
const prefix = lang === 'de' ? '' : `/${lang}`;
const homeHref = prefix || '/';

// Build href for switching to a target language while staying on the same page
function langUrl(code: string): string {
  const p = code === 'de' ? '' : `/${code}`;
  return `${p}${basePage}` || '/';
}
const langUrls = Object.fromEntries(Object.keys(languages).map(code => [code, langUrl(code)])) as Record<string, string>;
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-header">
  <div class="absolute inset-0 header-surface"></div>
  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 transition-all duration-500" id="header-inner">
      <!-- Logo -->
      <a href={homeHref} class="flex items-center gap-3 group">
        <img
          src="/images/logo.svg"
          alt="Barbier Berlin Logo"
          width="44"
          height="44"
          class="w-11 h-11 transition-transform duration-300 group-hover:scale-110"
        />
        <div class="hidden sm:block">
          <span class="font-display text-xl font-semibold tracking-wide" style="color: var(--text);">Barbier</span>
          <span class="font-display text-xl font-light ml-1" style="color: var(--gold);">Berlin</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        <a href={homeHref} class="nav-link">{tr.nav.home}</a>
        <a href={`${prefix}/services`} class="nav-link">{tr.nav.services}</a>
        <a href={`${prefix}/gallery`} class="nav-link">{tr.nav.gallery}</a>
        <a href={`${prefix}/about`} class="nav-link">{tr.nav.about}</a>
        <a href={`${prefix}/contact`} class="nav-link">{tr.nav.contact}</a>
      </div>

      <!-- Right Side -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Theme Toggle -->
        <ThemeToggle lang={lang} />

        <!-- Language Switcher -->
        <div class="relative group">
          <button class="flex items-center gap-1.5 text-sm px-2 py-1 transition-colors uppercase tracking-wider font-medium" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="1.5"/><path stroke-width="1.5" d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            {lang}
          </button>
          <div class="absolute right-0 top-full mt-2 rounded-xl py-1.5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 lang-menu">
            {Object.entries(languages).map(([code, name]) => (
              <a
                href={langUrls[code]}
                class={`block px-5 py-2 text-sm whitespace-nowrap transition-colors lang-item ${
                  code === lang ? 'lang-item--active' : ''
                }`}
              >
                {name}
              </a>
            ))}
          </div>
        </div>

        <a href={`${prefix}/login`} class="text-sm transition-colors px-3 py-2" style="color: var(--text-muted);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">
          {tr.nav.login}
        </a>
        <a
          href={`${prefix}/booking`}
          class="cta-gold font-semibold text-sm px-5 py-2.5 rounded-full transition-all duration-300 active:scale-95"
        >
          {tr.nav.booking}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <MobileNav lang={lang} prefix={prefix} langUrls={langUrls} client:load />
    </div>
  </nav>
</header>

<style>
  @reference "../../styles/global.css";
  .header-surface {
    background: var(--header-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }
  .nav-link {
    @apply relative text-sm font-medium px-3 py-2 transition-colors duration-300;
    color: var(--text-muted);
  }
  .nav-link:hover { color: var(--text); }
  .nav-link::after {
    content: '';
    @apply absolute bottom-0 left-3 right-3 h-[2px] scale-x-0 origin-left transition-transform duration-300;
    background: var(--gold);
  }
  .nav-link:hover::after {
    @apply scale-x-100;
  }
  .lang-menu {
    background: var(--bg-elevated);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    box-shadow: 0 20px 40px var(--shadow-color);
  }
  .lang-item { color: var(--text-muted); }
  .lang-item:hover { color: var(--text); background: var(--glass); }
  .lang-item--active { color: var(--gold); }
  .lang-item--active:hover { color: var(--gold); }
  .cta-gold {
    background: linear-gradient(90deg, var(--gold), var(--gold-deep));
    color: #050506;
    box-shadow: 0 8px 24px rgba(200, 165, 90, 0.2);
  }
  .cta-gold:hover {
    background: linear-gradient(90deg, var(--gold-light), var(--gold));
    box-shadow: 0 12px 32px rgba(200, 165, 90, 0.3);
  }
</style>

<script>
  const header = document.getElementById('main-header');
  const headerInner = document.getElementById('header-inner');

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    if (header && headerInner) {
      if (scrollY > 50) {
        headerInner.style.height = '3.5rem';
        header.classList.add('header-scrolled');
      } else {
        headerInner.style.height = '';
        header.classList.remove('header-scrolled');
      }
    }
  });
</script>
