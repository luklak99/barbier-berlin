---
import { t, type Language } from '../../i18n/translations';

interface Props {
  lang?: Language;
}

const { lang = 'de' } = Astro.props;
const tr = t(lang);
---

<footer class="bg-surface-950 text-white/60 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold-400 to-gold-600 flex items-center justify-center">
            <span class="text-surface-950 font-display font-bold text-lg">B</span>
          </div>
          <div>
            <span class="text-white font-display text-xl font-semibold">Barbier</span>
            <span class="text-gold-400 font-display text-xl font-light ml-1">Berlin</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed">
          {lang === 'de'
            ? 'Premium-Barbershop im Herzen von Kreuzberg. Präzise Haarschnitte, klassische Rasur und erstklassige Pflege.'
            : lang === 'en'
              ? 'Premium barbershop in the heart of Kreuzberg. Precise haircuts, classic shaves and first-class grooming.'
              : lang === 'tr'
                ? "Kreuzberg'in kalbinde premium berber. Hassas sac kesimi, klasik tras ve birinci sinif bakim."
                : 'صالون حلاقة فاخر في قلب كرويتسبرغ. قصات شعر دقيقة، حلاقة كلاسيكية وعناية فائقة.'}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-gold-400 transition-colors">{tr.nav.home}</a></li>
          <li><a href="/services" class="hover:text-gold-400 transition-colors">{tr.nav.services}</a></li>
          <li><a href="/gallery" class="hover:text-gold-400 transition-colors">{tr.nav.gallery}</a></li>
          <li><a href="/about" class="hover:text-gold-400 transition-colors">{tr.nav.about}</a></li>
          <li><a href="/contact" class="hover:text-gold-400 transition-colors">{tr.nav.contact}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">{tr.contact.title}</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>Markgrafenstraße 88<br />10969 Berlin</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:+493025926500" class="hover:text-gold-400 transition-colors">030 259 265 00</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href="mailto:info@barbier.berlin" class="hover:text-gold-400 transition-colors">info@barbier.berlin</a>
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">{tr.contact.hours}</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex justify-between"><span>{tr.common.monday} - {tr.common.friday}</span><span class="text-white">10:00 - 18:00</span></li>
          <li class="flex justify-between"><span>{tr.common.saturday}</span><span class="text-white">10:00 - 17:00</span></li>
          <li class="flex justify-between"><span>{tr.common.sunday}</span><span class="text-gold-400">{tr.common.closed}</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/5 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <p>&copy; {new Date().getFullYear()} Barbier Berlin. {tr.footer.rights}</p>
      <div class="flex gap-6">
        <a href="/impressum" class="hover:text-gold-400 transition-colors">{tr.footer.imprint}</a>
        <a href="/datenschutz" class="hover:text-gold-400 transition-colors">{tr.footer.privacy}</a>
      </div>
    </div>
  </div>
</footer>
