---
import { t, type Language } from '../../i18n/translations';
import OpeningHours from '../ui/OpeningHours.astro';

interface Props {
  lang?: Language;
}

const { lang = 'de' } = Astro.props;
const tr = t(lang);
const prefix = lang === 'de' ? '' : `/${lang}`;
---

<footer class="relative bg-[#050506] text-[#8A8F98]">
  <!-- Gold gradient top border -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C8A55A]/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.svg" alt="Barbier Berlin Logo" width="44" height="44" class="w-11 h-11" />
          <div>
            <span class="text-[#EDEDEF] font-display text-xl font-semibold">Barbier</span>
            <span class="text-[#C8A55A] font-display text-xl font-light ml-1">Berlin</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed">
          {lang === 'de'
            ? 'Premium-Barbershop im Herzen von Kreuzberg. Praezise Haarschnitte, klassische Rasur und erstklassige Pflege.'
            : lang === 'en'
              ? 'Premium barbershop in the heart of Kreuzberg. Precise haircuts, classic shaves and first-class grooming.'
              : lang === 'tr'
                ? "Kreuzberg'in kalbinde premium berber. Hassas sac kesimi, klasik tras ve birinci sinif bakim."
                : 'صالون حلاقة فاخر في قلب كرويتسبرغ. قصات شعر دقيقة، حلاقة كلاسيكية وعناية فائقة.'}
        </p>
        <!-- Social Icons -->
        <div class="flex gap-3 mt-5">
          <a href="https://www.instagram.com/barbier.berlin" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-white/[0.03] border border-white/[0.06] flex items-center justify-center text-[#8A8F98] hover:text-[#C8A55A] hover:border-[#C8A55A]/30 hover:bg-[#C8A55A]/5 transition-all duration-300" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://maps.app.goo.gl/Ed2sUihwZV5pMmHb6" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-white/[0.03] border border-white/[0.06] flex items-center justify-center text-[#8A8F98] hover:text-[#C8A55A] hover:border-[#C8A55A]/30 hover:bg-[#C8A55A]/5 transition-all duration-300" aria-label="Google Maps">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </a>
          <a href="tel:+493025926500" class="w-9 h-9 rounded-lg bg-white/[0.03] border border-white/[0.06] flex items-center justify-center text-[#8A8F98] hover:text-[#C8A55A] hover:border-[#C8A55A]/30 hover:bg-[#C8A55A]/5 transition-all duration-300" aria-label="Telefon">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-[#EDEDEF] font-semibold text-sm uppercase tracking-wider mb-4">Navigation</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={prefix || '/'} class="footer-link">{tr.nav.home}</a></li>
          <li><a href={`${prefix}/services`} class="footer-link">{tr.nav.services}</a></li>
          <li><a href={`${prefix}/gallery`} class="footer-link">{tr.nav.gallery}</a></li>
          <li><a href={`${prefix}/about`} class="footer-link">{tr.nav.about}</a></li>
          <li><a href={`${prefix}/contact`} class="footer-link">{tr.nav.contact}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-[#EDEDEF] font-semibold text-sm uppercase tracking-wider mb-4">{tr.contact.title}</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-[#C8A55A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>Markgrafenstra&szlig;e 88<br />10969 Berlin</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#C8A55A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:+493025926500" class="footer-link">030 259 265 00</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#C8A55A] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href="mailto:info@barbier.berlin" class="footer-link">info@barbier.berlin</a>
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="text-[#EDEDEF] font-semibold text-sm uppercase tracking-wider mb-4">{tr.contact.hours}</h3>
        <OpeningHours lang={lang} />
        <ul class="space-y-2 text-sm">
          <li class="flex justify-between"><span>{tr.common.monday} - {tr.common.friday}</span><span class="text-[#EDEDEF]">10:00 - 18:00</span></li>
          <li class="flex justify-between"><span>{tr.common.saturday}</span><span class="text-[#EDEDEF]">10:00 - 17:00</span></li>
          <li class="flex justify-between"><span>{tr.common.sunday}</span><span class="text-[#C8A55A]">{tr.common.closed}</span></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="relative border-t border-white/[0.06] mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <p>&copy; {new Date().getFullYear()} Barbier Berlin. {tr.footer.rights}</p>
      <div class="flex gap-6">
        <a href={`${prefix}/impressum`} class="footer-link">{tr.footer.imprint}</a>
        <a href={`${prefix}/datenschutz`} class="footer-link">{tr.footer.privacy}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  @reference "../../styles/global.css";
  .footer-link {
    @apply text-[#8A8F98] hover:text-[#C8A55A] transition-colors duration-300;
  }
</style>
